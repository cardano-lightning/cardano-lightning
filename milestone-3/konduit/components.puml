@startuml
skinparam componentStyle uml2

package "Konduit L2 Server" {

  [HTTP Server\n(Axum + Router)] as Server

  component "Channel Manager" as Channel <<core>>
  component "State Manager\n(konduit-data)" as State <<core>>
  component "Transaction Builder\n(konduit-tx)" as Tx <<core>>
  component "Admin & Cron" as Admin <<aux>>
  component "API Types\n(konduit-api)" as Api

  note right of Channel
    <b>Core</b>
    • Squash / quote / pay channels
    • Empirical: channel hold time, timeouts
  end note

  note right of Admin
    <b>Auxiliary</b>
    background jobs + admin endpoints
  end note
}

component "Cardano Adapter" as CardanoAdapter

note right of CardanoAdapter
  <b>L1 Interaction</b>
  • Read / store: chain indexer
  • Write: submit transactions
end note


cloud "Cardano L1" as L1
cloud "External FX" as FX

Server --> Channel : uses
Server --> State : uses
Server --> Admin : uses
Server --> Api : uses
Server --> FX : queries rates

Channel --> State : reads / writes
Channel --> Tx : uses
Channel --> CardanoAdapter : uses

Tx --> CardanoAdapter : uses
Admin --> State : syncs / inspects
Admin --> CardanoAdapter : queries tip

CardanoAdapter ..> L1 : reads (tip / indexer / UTxOs)
CardanoAdapter --> L1 : submits txs

@enduml
