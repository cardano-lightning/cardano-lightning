@startuml
skinparam componentStyle uml2
skinparam shadowing false
skinparam nodesep 20
skinparam ranksep 10


<style>
component {
    HorizontalAlignment center   /* works in many cases */
}
arrow {
    LineColor gray
    LineThickness 1
}

</style>

package "Gateway Node" as CLNode {
    database DB as DB {
      component ChannelInfo <<record>> [
        <b>Channel
      ]
    }

    component Server <<service>> [
        <b>Server
    ]
    Server -d--> DB

    interface "<b>HTTP" as HTTP
    component Client <<library>> [
      <b>Client
    ]
    component CLI <<application>> [
      <b>CLI Client
    ]
    component WASM <<library>> [
      <b> WASM Client
    ]
    CLI -u--> Client
    WASM -u---> Client
    Client -u-->HTTP
    Server -d- HTTP

    component Kernel <<smart-contract>> [
      <b>Kernel in Aiken
    ]
    interface "<b>Plutus Binaries" as PlutusBinaries
    PlutusBinaries -u- Kernel

    component TxBuilder <<library>> [
        <b>Tx Builder
    ]

    TxBuilder -u--> PlutusBinaries

    component CLData <<library>> [
      <b>CL Data
    ]

    interface "<b>Codecs" as Codecs

    Codecs -u- CLData

    TxBuilder -u--> Codecs

    component Admin <<service>> [
      <b>Admin

      <i>L1 monitoring
      <i>L1 liquidity management
    ]

    Admin -u--> TxBuilder

    Admin -u--> DB
}

package Protocols as Protocols {
  component ProblemDetails <<library>> [
    <b>"Problem Details"

    <i>RFC 9457 based
    <i>HTTP error reporting.
  ]

  component Cobbl3 <<library>> [
    <b>"Cobbl3"

    <i>A very simple HMAC-BLAKE3
    <i>auth protocol.
  ]

  component Powdos <<library>> [
    <b>"Powdos"

    <i>Crypto-agnostic proof-of-work challenge.
    <i>Issue, solve, verify.
  ]

}

package "<b>FX</b>" as FX {
  interface "<b>Query</b>" as FXAPI <<api>>
  component "<b>Kraken</b>" as Kraken <<adapter>>
  Kraken -l-..|> FXAPI: implements
}


  package "BLN" as BLN {
    component "<b>BLN SDK</b>" as BLNSDK <<library>>

    interface "<b>BLN Connector</b>" as BLNConnector <<api>>
    component "<b>LND Client</b>" as LndAdapter <<adapter>>
    LndAdapter -u-..|> BLNConnector: implements

  }

package Cardano as Cardano {
  interface "<b>Cardano Connector</b>" as CardanoConnector <<api>>

  component "<b>Blockfrost" as BlockfrostAdapter <<adapter>>
  component "<b>UTxO RPC" as UTxORPCAdapter <<adapter>>
  component "<b>Kupo" as KupoAdapter <<adapter>>

  BlockfrostAdapter -u-..|> CardanoConnector: implements
  UTxORPCAdapter -u-..|> CardanoConnector: implements
  KupoAdapter -u-..|> CardanoConnector: implements

  component CardanoSDK <<library>> [
    <b>Cardano SDK</b>
  ]

  component TxSubmission <<service>> [
    <b>Tx Submission

    <i>With retries
    <i>& status tracking.
  ]
}


'CLData -d--> CardanoSDK
'TxBuilder -d--> CardanoSDK
Admin -d--> CardanoConnector
Admin -d--> TxSubmission

Admin -d--> BLNConnector
Admin -d--> BLNSDK

Server -d--> ProblemDetails
Server -d--> Cobbl3
Server -d--> Powdos
Server -d--> FXAPI

@enduml
